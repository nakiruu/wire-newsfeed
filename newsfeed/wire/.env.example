# Copy this file to .env and fill in your values before running docker compose.
# These are baked into the app bundle at build time — rebuild after any change.

# Your self-hosted cors-anywhere address
VITE_CORS_PROXY_URL=http://192.168.1.155:7824

# Your article extractor address (spun up automatically by docker compose on port 7825)
VITE_ARTICLE_EXTRACTOR_URL=http://192.168.1.155:7825

# Financial Modeling Prep API key (https://financialmodelingprep.com)
VITE_FMP_API_KEY=

# Alpaca Markets API key — format: keyId:secretKey
VITE_ALPACA_API_KEY=

# Browserless internal URL (only needed when using --profile reader)
BROWSERLESS_URL=http://browserless:3000
